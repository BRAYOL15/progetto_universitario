<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="10.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.progetto_universitario.MainController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <Label text="Sistema di Prenotazione Voli - Pannello Universitario">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        <HBox spacing="10.0">
            <children>
                <TextField fx:id="txtPartenza" promptText="Partenza (es. Bologna)" />
                <TextField fx:id="txtDestinazione" promptText="Destinazione (es. Roma)" />
                <Button mnemonicParsing="false" onAction="#gestisciCerca" text="Cerca Voli" />
            </children>
        </HBox>
        <TableView fx:id="tabellaVoli" prefHeight="250.0" prefWidth="770.0">
            <columns>
                <TableColumn fx:id="colCodice" prefWidth="100.0" text="Codice Volo" />
                <TableColumn fx:id="colCompagnia" prefWidth="120.0" text="Compagnia" />
                <TableColumn fx:id="colPartenza" prefWidth="120.0" text="Partenza" />
                <TableColumn fx:id="colDestinazione" prefWidth="120.0" text="Destinazione" />
                <TableColumn fx:id="colPosti" prefWidth="100.0" text="Posti Disponibili" />
                <TableColumn fx:id="colPrezzo" prefWidth="110.0" text="Prezzo Finale" />
            </columns>
        </TableView>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <TextField fx:id="txtNomePasseggero" promptText="Nome Passeggero" />
                <Button mnemonicParsing="false" onAction="#gestisciPrenota" text="Prenota Volo Selezionato" />
            </children>
        </HBox>
        <Label text="Console Log - Aggiornamenti Thread in Tempo Reale :">
            <font>
                <Font name="System Italic" size="12.0" />
            </font>
        </Label>
        <TextArea fx:id="txtAreaLog" editable="false" prefHeight="150.0" prefWidth="770.0" />
    </children>
</VBox>
